{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bus Message",
  "description": "Schema for coordination bus messages",
  "type": "object",
  "required": ["timestamp", "from", "to", "type", "message"],
  "additionalProperties": false,
  "properties": {
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp with Z suffix"
    },
    "from": {
      "type": "string",
      "minLength": 1,
      "description": "Sender agent identifier"
    },
    "to": {
      "type": "string",
      "minLength": 1,
      "description": "Recipient (agent ID or 'all')"
    },
    "type": {
      "type": "string",
      "enum": ["STATUS", "PROPOSAL", "ACK", "BLOCKED", "DECISION", "MILESTONE"],
      "description": "Message type"
    },
    "message": {
      "type": "string",
      "maxLength": 4096,
      "description": "Message content"
    }
  }
}
